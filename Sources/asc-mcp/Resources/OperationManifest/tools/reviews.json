      "operations": [
        {
          "operationId": "apps_customerReviews_getToManyRelated",
          "method": "get",
          "path": "/v1/apps/{id}/customerReviews",
          "role": "primary",
          "condition": "Uses limit=200 and sort=-createdDate. Streams and deduplicates each page by review ID without retaining all review bodies. Follows every page for all_time; bounded periods stop only after a page contains an item older than the inclusive rolling UTC boundary.",
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "limit",
              "fixedValue": 200
            },
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "sort",
              "fixedValue": ["-createdDate"]
            }
          ],
          "optionalParameterClassifications": [
            {
              "location": "query",
              "appleName": "filter[rating]",
              "disposition": "intentionallyOmitted",
              "reason": "The aggregate must retrieve every rating to calculate a complete 1-through-5 distribution.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[reviewTerritory]",
              "disposition": "intentionallyOmitted",
              "reason": "The statistics tool uses public alpha-3 filter[territory] values instead of opaque related territory resource IDs.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "include",
              "disposition": "intentionallyOmitted",
              "reason": "Statistics require only review attributes and do not download related response or territory resources.",
              "reviewAtSpec": "4.4.1"
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "app_id",
          "sourceKind": "parameter",
          "operationId": "apps_customerReviews_getToManyRelated",
          "location": "path",
          "appleName": "id"
        },
        {
          "toolField": "period",
          "sourceKind": "local",
          "localRole": "rollingUTCCreatedDateWindow"
        },
        {
          "toolField": "territory",
          "sourceKind": "parameter",
          "operationId": "apps_customerReviews_getToManyRelated",
          "location": "query",
          "appleName": "filter[territory]",
          "localRole": "valueAllOmitsAppleFilter"
        },
        {
          "toolField": "has_published_response",
          "sourceKind": "parameter",
          "operationId": "apps_customerReviews_getToManyRelated",
          "location": "query",
          "appleName": "exists[publishedResponse]"
        }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          {
            "operationId": "apps_customerReviews_getToManyRelated",
            "statusCode": "200",
            "mediaType": "application/json"
          }
        ],
        "fields": [
