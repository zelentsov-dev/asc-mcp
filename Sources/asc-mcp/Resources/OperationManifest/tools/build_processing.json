            "outputField": "processingState",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data/attributes/processingState"
          },
          {
            "outputField": "uploadedDate",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data/attributes/uploadedDate"
          },
          {
            "outputField": "timeSinceUpload",
            "localRole": "Derived from uploadedDate and the local clock."
          }
        ]
      },
      "note": "Non-blocking reduced Build projection; duplicates most of builds_get_processing_state."
    },
    {
      "tool": "builds_update_encryption",
      "kind": "direct",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "builds_updateInstance",
          "method": "patch",
          "path": "/v1/builds/{id}",
          "role": "primary",
          "inputs": [
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/type",
              "fixedValue": "builds"
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/id",
              "derivedFrom": [
                "build_id"
              ],
              "localRole": "Reuse the public build ID as the JSON:API resource ID in the intended update body."
            }
          ],
          "optionalParameterClassifications": [
            {
              "location": "body",
              "appleName": "/data/attributes/expired",
              "disposition": "intentionallyOmitted",
              "reason": "This narrowly scoped encryption-compliance tool must not also expire a TestFlight build; expiration requires a separately named destructive action.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "body",
              "appleName": "/data/relationships/appEncryptionDeclaration",
              "disposition": "intentionallyOmitted",
              "reason": "Linking an App Encryption Declaration is a distinct relationship workflow and is not inferred by the boolean encryption-compliance update.",
              "reviewAtSpec": "4.4.1"
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "builds_updateInstance",
          "location": "path",
          "appleName": "id"
        },
        {
          "toolField": "uses_non_exempt_encryption",
          "sourceKind": "requestBody",
          "operationId": "builds_updateInstance",
          "jsonPointer": "/data/attributes/usesNonExemptEncryption"
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          {
            "operationId": "builds_updateInstance",
            "statusCode": "200",
            "mediaType": "application/json"
          }
        ],
        "fields": [
          {
            "outputField": "build",
            "operationId": "builds_updateInstance",
            "jsonPointer": "/data"
          },
          {
            "outputField": "buildId",
            "operationId": "builds_updateInstance",
            "jsonPointer": "/data/id"
          },
          {
            "outputField": "usesNonExemptEncryption",
            "operationId": "builds_updateInstance",
            "jsonPointer": "/data/attributes/usesNonExemptEncryption"
          },
          {
            "outputField": "success",
            "localRole": "True after Apple accepts the build update."
          },
          {
            "outputField": "message",
            "localRole": "Local confirmation that encryption compliance was updated."
          }
        ]
      },
      "note": "PATCHes the Build resource directly with usesNonExemptEncryption and returns Apple's updated Build projection."
    }
  ],
  "implementationAliases": []
