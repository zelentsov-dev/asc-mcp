            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "path",
          "appleName": "id"
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
