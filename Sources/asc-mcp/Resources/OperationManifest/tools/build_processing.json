{
  "workerKey": "build_processing",
  "tools": [
    {
      "tool": "builds_check_readiness",
      "kind": "direct",
      "status": "partial",
      "effect": "read",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "builds_getInstance",
          "method": "get",
          "path": "/v1/builds/{id}",
          "role": "primary",
          "optionalParameterClassifications": [
            {
              "location": "query",
              "appleName": "include",
              "disposition": "internalControl",
              "reason": "Readiness always includes buildBetaDetail because TestFlight states are required for the documented result.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[betaBuildLocalizations]",
              "disposition": "intentionallyOmitted",
              "reason": "Beta build localizations are not included in readiness checks.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[betaGroups]",
              "disposition": "intentionallyOmitted",
              "reason": "Beta groups are not included in readiness checks.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[buildBundles]",
              "disposition": "intentionallyOmitted",
              "reason": "Build bundles are not included in readiness checks.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[icons]",
              "disposition": "intentionallyOmitted",
              "reason": "Build icons are not included in readiness checks.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[individualTesters]",
              "disposition": "intentionallyOmitted",
              "reason": "Individual testers are not included in readiness checks.",
              "reviewAtSpec": "4.4.1"
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "path",
          "appleName": "id"
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          {
            "operationId": "builds_getInstance",
            "statusCode": "200",
            "mediaType": "application/json"
          }
        ],
        "fields": [
          {
            "outputField": "states",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data"
          },
          {
            "outputField": "readiness",
            "localRole": "Locally derived heuristic from processing, encryption, expiration, and included build beta detail fields."
          },
          {
            "outputField": "issues",
            "localRole": "Locally generated diagnostic strings."
          },
          {
            "outputField": "warnings",
            "localRole": "Locally generated export-compliance and App Store submission-scope warnings."
          },
          {
            "outputField": "betaDetails",
            "operationId": "builds_getInstance",
            "jsonPointer": "/included"
          },
          {
            "outputField": "version",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data/attributes/version"
          },
          {
            "outputField": "minOsVersion",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data/attributes/minOsVersion"
          },
          {
            "outputField": "buildId",
            "localRole": "Echo of the validated public build identifier."
          },
          {
            "outputField": "success",
            "localRole": "True after Apple returns the Build resource used for the readiness projection."
          }
        ]
      },
      "note": "Reports build prerequisites and only current testable TestFlight states. Expired and pre-review builds are not marked testable, and App Store version submission status is explicitly NOT_DETERMINED."
    },
    {
      "tool": "builds_get_processing_state",
      "kind": "direct",
      "status": "partial",
      "effect": "read",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "builds_getInstance",
          "method": "get",
          "path": "/v1/builds/{id}",
          "role": "primary",
          "optionalParameterClassifications": [
            {
              "location": "query",
              "appleName": "include",
              "disposition": "intentionallyOmitted",
              "reason": "Processing state is a reduced Build projection and does not include related resources.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[betaBuildLocalizations]",
