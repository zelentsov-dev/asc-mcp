              "reviewAtSpec": "4.4.1"
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "path",
          "appleName": "id"
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          {
            "operationId": "builds_getInstance",
            "statusCode": "200",
            "mediaType": "application/json"
          }
        ],
        "fields": [
          {
            "outputField": "processingState",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data/attributes/processingState"
          },
          {
            "outputField": "uploadedDate",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data/attributes/uploadedDate"
          },
          {
            "outputField": "processingDuration",
            "localRole": "Derived from uploadedDate and the local clock while processing."
          }
        ]
      },
      "note": "Reduced Build projection with local state description; overlaps builds_get_processing_status."
    },
