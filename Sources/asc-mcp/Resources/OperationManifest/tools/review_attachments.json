    {
      "tool": "review_attachments_upload",
      "kind": "compound",
      "status": "partial",
      "effect": "write",
      "implementationState": "target",
      "operations": [
        {
          "operationId": "appStoreReviewAttachments_createInstance",
          "method": "post",
          "path": "/v1/appStoreReviewAttachments",
          "role": "primary",
          "inputs": [
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/type",
              "fixedValue": "appStoreReviewAttachments"
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/relationships/appStoreReviewDetail/data/type",
              "fixedValue": "appStoreReviewDetails"
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_updateInstance",
          "method": "patch",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "supporting",
          "condition": "After all presigned upload operations succeed, commit the derived checksum with uploaded=true using the attachment ID returned by create.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Use the attachment ID returned by the reservation response."
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Copy the reservation response ID into the commit resource identifier."
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/type",
              "fixedValue": "appStoreReviewAttachments"
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/attributes/uploaded",
              "fixedValue": true
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_getInstance",
          "method": "get",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "conditional",
          "condition": "After commit, poll the created attachment until assetDeliveryState reaches a terminal state.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Poll the attachment created by the reservation operation."
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_deleteInstance",
          "method": "delete",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "conditional",
          "condition": "If reserve succeeds but upload, commit, or delivery fails, delete the created attachment as cleanup.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Delete the attachment created by the reservation operation when cleanup is required."
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "review_detail_id",
          "sourceKind": "requestBody",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/relationships/appStoreReviewDetail/data/id"
        },
        {
          "toolField": "file_path",
          "sourceKind": "local",
          "localRole": "Read the local file and upload its bytes through the presigned uploadOperations returned by Apple; presigned transfers are outside the App Store Connect OpenAPI."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/attributes/fileSize",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive the reservation fileSize from the local file."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/attributes/fileName",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive the reservation fileName from the local path."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_updateInstance",
          "jsonPointer": "/data/attributes/sourceFileChecksum",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive the sourceFileChecksum while uploading the local file."
        }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "appStoreReviewAttachments_createInstance", "statusCode": "201", "mediaType": "application/json" },
          { "operationId": "appStoreReviewAttachments_deleteInstance", "statusCode": "204" },
          { "operationId": "appStoreReviewAttachments_getInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "appStoreReviewAttachments_updateInstance", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": [
          {
            "outputField": "success",
            "localRole": "Set true after reserve, presigned upload, and commit all return successfully."
          },
          {
            "outputField": "attachment",
            "operationId": "appStoreReviewAttachments_getInstance",
            "jsonPointer": "/data",
            "localRole": "Use the terminal poll response; the current handler instead projects the immediate commit response."
          }
        ]
      },
      "note": "Intended current workflow is reserve, local presigned upload, then commit. Mapping is partial because the handler does not poll assetDeliveryState to COMPLETE or delete a reservation after upload failure, and the tool has no outputSchema."
