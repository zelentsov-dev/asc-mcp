    {
      "tool": "review_attachments_upload",
      "kind": "compound",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "appStoreReviewAttachments_createInstance",
          "method": "post",
          "path": "/v1/appStoreReviewAttachments",
          "role": "primary",
          "condition": "After creating an immutable local snapshot, reserve an attachment with metadata derived from that snapshot and receive Apple's signed upload operations.",
          "inputs": [
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/type",
              "fixedValue": "appStoreReviewAttachments"
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/relationships/appStoreReviewDetail/data/type",
              "fixedValue": "appStoreReviewDetails"
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_updateInstance",
          "method": "patch",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "supporting",
          "condition": "After all presigned upload operations succeed, commit the derived checksum with uploaded=true using the attachment ID returned by create.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Use the attachment ID returned by the reservation response."
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Copy the reservation response ID into the commit resource identifier."
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/type",
              "fixedValue": "appStoreReviewAttachments"
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/attributes/uploaded",
              "fixedValue": true
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_getInstance",
          "method": "get",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "conditional",
          "condition": "When the commit response is nonterminal or the commit outcome is ambiguous, reconcile the created attachment until assetDeliveryState reaches a terminal state unless the task is cancelled.",
          "optionalParameterClassifications": [
            {
              "location": "query",
              "appleName": "include",
              "disposition": "intentionallyOmitted",
              "reason": "Upload reconciliation needs attachment delivery state and relationship identity only; expanding reviewer contact or demo-account data is unrelated to delivery verification.",
              "reviewAtSpec": "4.4.1"
            }
          ],
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Poll the attachment created by the reservation operation."
            },
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appStoreReviewAttachments]",
              "fixedValue": [
                "fileSize",
                "fileName",
                "sourceFileChecksum",
                "assetDeliveryState",
                "appStoreReviewDetail"
              ]
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_deleteInstance",
          "method": "delete",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "conditional",
          "condition": "Before any commit PATCH is attempted, best-effort delete a confirmed reservation when cancellation, a missing upload plan, byte-transfer failure, or commit-body preparation prevents commit; treat 404 as already absent.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Rollback only the known reservation for this upload attempt, independently of caller cancellation."
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "review_detail_id",
          "sourceKind": "requestBody",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/relationships/appStoreReviewDetail/data/id"
        },
        {
          "toolField": "file_path",
          "sourceKind": "local",
          "localRole": "Create an immutable temporary snapshot of the local file and upload those bytes through Apple's presigned uploadOperations; presigned transfers are outside the App Store Connect OpenAPI."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/attributes/fileSize",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive the reservation fileSize from the immutable snapshot."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/attributes/fileName",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive the reservation fileName associated with the immutable snapshot."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_updateInstance",
          "jsonPointer": "/data/attributes/sourceFileChecksum",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive sourceFileChecksum from the same immutable snapshot bytes sent through every upload operation."
        }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "appStoreReviewAttachments_createInstance", "statusCode": "201", "mediaType": "application/json" },
          { "operationId": "appStoreReviewAttachments_deleteInstance", "statusCode": "204" },
          { "operationId": "appStoreReviewAttachments_getInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "appStoreReviewAttachments_updateInstance", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": [
          {
            "outputField": "success",
            "localRole": "Set true when processing reaches COMPLETE or when a confirmed 2xx commit remains accepted processing-pending; ambiguous commit, unexpected-resource, and FAILED outcomes remain false."
          },
          {
            "outputField": "attachment",
            "localRole": "Project the latest attachment returned by commit or reconciliation, including nonterminal and FAILED states."
          },
          {
            "outputField": "uploadCommitted",
            "localRole": "Set true for an accepted processing-pending result after the commit PATCH returned 2xx."
          },
          {
            "outputField": "processingComplete",
            "localRole": "Set false for an accepted processing-pending result."
          },
          {
            "outputField": "deliveryPending",
            "localRole": "Set true while a confirmed commit is still processing and for unresolved ambiguous post-PATCH outcomes."
          },
          {
            "outputField": "retrySafe",
            "localRole": "Set false for accepted processing-pending and every unresolved post-reservation outcome to prevent duplicate reservations."
          },
          {
            "outputField": "cleanup",
            "localRole": "Describe rollback status or provide review_attachments_get and review_attachments_delete guidance for retained post-PATCH resources."
          }
        ]
      },
      "note": "The handler snapshots the local file before reserve, derives reservation metadata, transfer bytes, and checksum from that immutable snapshot, then commits and reconciles assetDeliveryState. COMPLETE is successful; FAILED is terminal failure; missing, unknown, and every other state remain pending and are polled with conditional GET. After a confirmed 2xx commit, nonterminal processing or unavailable verification is an accepted success with uploadCommitted=true, processingComplete=false, deliveryPending=true, and retrySafe=false. If PATCH transport remains ambiguous and reconciliation only shows pending, the outcome stays an error. A mismatched 2xx commit attachment triggers one GET of the expected attachment ID; valid COMPLETE, FAILED, or pending state is interpreted normally, while failed, unreadable, or mismatched reconciliation remains a retained error. All post-PATCH outcomes retain the attachment with explicit get/delete guidance. A confirmed reservation that fails before PATCH is best-effort deleted independently of cancellation. If create may have succeeded but its response or ID is unavailable, Apple exposes no idempotency key for identifying that exact reservation, so the handler reports retrySafe=false and review-detail collection inspection guidance instead of silently reserving again. The mapping remains partial because the MCP output has no outputSchema."
    }
  ],
