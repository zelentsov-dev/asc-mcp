    {
      "tool": "review_attachments_upload",
      "kind": "compound",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "appStoreReviewAttachments_createInstance",
          "method": "post",
          "path": "/v1/appStoreReviewAttachments",
          "role": "primary",
          "inputs": [
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/type",
              "fixedValue": "appStoreReviewAttachments"
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/relationships/appStoreReviewDetail/data/type",
              "fixedValue": "appStoreReviewDetails"
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_updateInstance",
          "method": "patch",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "supporting",
          "condition": "After all presigned upload operations succeed, commit the derived checksum with uploaded=true using the attachment ID returned by create.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Use the attachment ID returned by the reservation response."
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Copy the reservation response ID into the commit resource identifier."
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/type",
              "fixedValue": "appStoreReviewAttachments"
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/attributes/uploaded",
              "fixedValue": true
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_getInstance",
          "method": "get",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "conditional",
          "condition": "When the commit response is nonterminal or the commit outcome is ambiguous, reconcile the created attachment until assetDeliveryState reaches a terminal state unless the task is cancelled.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Poll the attachment created by the reservation operation."
            }
          ]
        },
        {
          "operationId": "appStoreReviewAttachments_deleteInstance",
          "method": "delete",
          "path": "/v1/appStoreReviewAttachments/{id}",
          "role": "conditional",
          "condition": "Before any commit PATCH is attempted, delete the reservation only when Apple returns no upload operations or the presigned byte transfer fails. Treat a 404 cleanup response as already absent.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": [
                "appStoreReviewAttachments_createInstance:/data/id"
              ],
              "localRole": "Rollback the reservation only for a missing upload plan or presigned transfer failure before commit."
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "review_detail_id",
          "sourceKind": "requestBody",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/relationships/appStoreReviewDetail/data/id"
        },
        {
          "toolField": "file_path",
          "sourceKind": "local",
          "localRole": "Create an immutable temporary snapshot of the local file and upload those bytes through Apple's presigned uploadOperations; presigned transfers are outside the App Store Connect OpenAPI."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/attributes/fileSize",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive the reservation fileSize from the local file."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_createInstance",
          "jsonPointer": "/data/attributes/fileName",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive the reservation fileName from the local path."
        },
        {
          "toolField": "file_path",
          "sourceKind": "derived",
          "operationId": "appStoreReviewAttachments_updateInstance",
          "jsonPointer": "/data/attributes/sourceFileChecksum",
          "derivedFrom": [
            "file_path"
          ],
          "localRole": "Derive sourceFileChecksum from the same immutable snapshot bytes sent through every upload operation."
        }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "appStoreReviewAttachments_createInstance", "statusCode": "201", "mediaType": "application/json" },
          { "operationId": "appStoreReviewAttachments_deleteInstance", "statusCode": "204" },
          { "operationId": "appStoreReviewAttachments_getInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "appStoreReviewAttachments_updateInstance", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": [
          {
            "outputField": "success",
            "localRole": "Set true only when the commit response or a reconciliation response reports COMPLETE."
          },
          {
            "outputField": "attachment",
            "localRole": "Project the latest attachment returned by commit or reconciliation, including nonterminal and FAILED states."
          }
        ]
      },
      "note": "The handler snapshots the local file, reserves, uploads, commits, and reconciles assetDeliveryState. Automatic DELETE is restricted to missing upload operations or transfer failure before PATCH. Once commit may have started, every error, cancellation, timeout, malformed response, and FAILED state retains the attachment with explicit get/delete guidance. The mapping remains partial because the MCP output has no outputSchema."
