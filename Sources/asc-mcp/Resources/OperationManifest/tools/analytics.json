          "operationId": "analyticsReports_instances_getToManyRelated",
          "method": "get",
          "path": "/v1/analyticsReports/{id}/instances",
          "role": "supporting",
          "condition": "Called once per locally filtered report with limit=1.",
          "optionalParameterClassifications": [
            {
              "location": "query",
              "appleName": "filter[granularity]",
              "disposition": "intentionallyOmitted",
              "reason": "The readiness heuristic only needs to know whether any report instance exists, regardless of granularity.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[processingDate]",
              "disposition": "intentionallyOmitted",
              "reason": "The readiness heuristic only needs to know whether any report instance exists, regardless of processing date.",
              "reviewAtSpec": "4.4.1"
            }
          ],
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": ["analyticsReportRequests_reports_getToManyRelated:/data/*/id"],
              "localRole": "iterateFilteredReportIdentifiers"
            },
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "limit",
              "fixedValue": 1
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "request_id",
