            "outputField": "success",
            "localRole": "orchestrationEnvelope"
          },
          {
            "outputField": "request_id",
            "localRole": "requestIdentifierEcho"
          },
          {
            "outputField": "total_reports",
            "localRole": "filteredReportCount"
          },
          {
            "outputField": "reports",
            "operationId": "analyticsReportRequests_reports_getToManyRelated",
            "jsonPointer": "/data",
            "localRole": "joinedWithOneInstanceProbePerReport"
          },
          {
            "outputField": "ready",
            "localRole": "reportsWithAtLeastOneReturnedInstance"
          },
          {
            "outputField": "pending",
            "localRole": "reportsWithNoReturnedInstance"
