    {
      "tool": "users_update",
      "kind": "direct",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "users_updateInstance",
          "method": "patch",
          "path": "/v1/users/{id}",
          "role": "primary",
          "inputs": [
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "users" },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/visibleApps/data/*/type", "fixedValue": "apps" }
          ]
        }
      ],
      "fields": [
        { "toolField": "user_id", "sourceKind": "parameter", "operationId": "users_updateInstance", "location": "path", "appleName": "id" },
        { "toolField": "user_id", "sourceKind": "requestBody", "operationId": "users_updateInstance", "jsonPointer": "/data/id" },
        { "toolField": "roles", "sourceKind": "requestBody", "operationId": "users_updateInstance", "jsonPointer": "/data/attributes/roles", "localRole": "validated against Apple 4.4.1 UserRole values; ACCESS_TO_REPORTS remains accepted with a deprecation warning" },
        { "toolField": "all_apps_visible", "sourceKind": "requestBody", "operationId": "users_updateInstance", "jsonPointer": "/data/attributes/allAppsVisible" },
        { "toolField": "provisioning_allowed", "sourceKind": "requestBody", "operationId": "users_updateInstance", "jsonPointer": "/data/attributes/provisioningAllowed" },
        { "toolField": "visible_app_ids", "sourceKind": "requestBody", "operationId": "users_updateInstance", "jsonPointer": "/data/relationships/visibleApps/data/*/id", "localRole": "each non-empty unique ID is encoded as an apps resource linkage; an empty array clears the relationship" }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          { "operationId": "users_updateInstance", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": [
          { "outputField": "user", "operationId": "users_updateInstance", "jsonPointer": "/data" },
          { "outputField": "warnings", "localRole": "present when deprecated ACCESS_TO_REPORTS is submitted" }
        ]
      },
      "note": "Covers every writable field in Apple 4.4.1 UserUpdateRequest. At least one update field is required locally. TECHNICAL and unknown roles are rejected before the request; ACCESS_TO_REPORTS remains accepted for compatibility because it is still in Apple's enum, with an explicit deprecation warning from current Apple documentation. No local mutual exclusion is imposed between allAppsVisible and visibleApps because Apple 4.4.1 declares both optional without a cross-field constraint; Apple remains responsible for account-specific validation. The response formatter remains a selected projection of Apple's User resource."
    }
