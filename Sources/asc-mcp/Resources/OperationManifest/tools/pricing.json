          "sourceKind": "requestBody",
          "operationId": "appAvailabilitiesV2_createInstance",
          "jsonPointer": "/included/*/attributes/available",
          "localRole": "Map each nullable available value; omission and explicit null both encode as JSON null."
        },
        {
          "toolField": "territory_availabilities",
          "sourceKind": "requestBody",
          "operationId": "appAvailabilitiesV2_createInstance",
          "jsonPointer": "/included/*/attributes/releaseDate",
          "localRole": "Map each nullable release_date value after strict date validation; omission and explicit null both encode as JSON null."
