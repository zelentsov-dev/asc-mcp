    {
      "tool": "pricing_set_price_schedule",
      "kind": "direct",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "appPriceSchedules_createInstance",
          "method": "post",
          "path": "/v1/appPriceSchedules",
          "role": "primary",
          "inputs": [
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "appPriceSchedules" },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/app/data/type", "fixedValue": "apps" },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/baseTerritory/data/type", "fixedValue": "territories" },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/manualPrices/data/*/type", "fixedValue": "appPrices" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/relationships/manualPrices/data/*/id",
              "derivedFrom": ["local:inlinePriceId"],
              "localRole": "reuseGeneratedInlinePriceIdentifier"
            },
            { "sourceKind": "fixed", "jsonPointer": "/included/*/type", "fixedValue": "appPrices" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/included/*/id",
              "derivedFrom": ["local:inlinePriceId"],
              "localRole": "reuseGeneratedInlinePriceIdentifier"
            },
            { "sourceKind": "fixed", "jsonPointer": "/included/*/relationships/appPricePoint/data/type", "fixedValue": "appPricePoints" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/included/*/relationships/appPricePoint/data/id",
              "derivedFrom": ["price_point_id"],
              "localRole": "embedSelectedAppPricePointIdentifier"
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "app_id",
          "sourceKind": "requestBody",
          "operationId": "appPriceSchedules_createInstance",
          "jsonPointer": "/data/relationships/app/data/id"
        },
        {
          "toolField": "base_territory_id",
          "sourceKind": "requestBody",
          "operationId": "appPriceSchedules_createInstance",
          "jsonPointer": "/data/relationships/baseTerritory/data/id"
        },
        {
          "toolField": "price_point_id",
          "sourceKind": "requestBody",
          "operationId": "appPriceSchedules_createInstance",
          "jsonPointer": "/included",
          "localRole": "Build one inline appPrices resource and link it from data.relationships.manualPrices."
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          {
