            "operationId": "appAvailabilitiesV2_createInstance",
            "jsonPointer": "/data/type"
          },
          {
            "outputField": "availability.availableInNewTerritories",
            "operationId": "appAvailabilitiesV2_createInstance",
            "jsonPointer": "/data/attributes/availableInNewTerritories"
