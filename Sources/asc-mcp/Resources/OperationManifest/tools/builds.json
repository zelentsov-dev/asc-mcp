{
  "workerKey": "builds",
  "tools": [
    {
      "tool": "builds_find_by_number",
      "kind": "direct",
      "status": "partial",
      "effect": "read",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "builds_getCollection",
          "method": "get",
          "path": "/v1/builds",
          "role": "primary",
          "optionalParameterClassifications": [
            {
              "location": "query",
              "appleName": "include",
              "disposition": "internalControl",
              "reason": "The finder fixes include to app, buildBetaDetail, and preReleaseVersion so a stable match projection can be produced.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit",
              "disposition": "internalControl",
              "reason": "The singular finder fixes limit to one after applying deterministic filters and sort.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "exists[usesNonExemptEncryption]",
              "disposition": "intentionallyOmitted",
              "reason": "Encryption-presence filtering belongs to builds_list; this tool is intentionally scoped to exact build-number lookup.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[appStoreVersion]",
              "disposition": "intentionallyOmitted",
              "reason": "App Store version filtering belongs to builds_list; the finder supports platform and pre-release disambiguation.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[betaAppReviewSubmission.betaReviewState]",
              "disposition": "intentionallyOmitted",
              "reason": "Beta review-state filtering belongs to builds_list, not exact build-number lookup.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[betaGroups]",
              "disposition": "intentionallyOmitted",
              "reason": "Beta-group filtering belongs to builds_list, not exact build-number lookup.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[buildAudienceType]",
              "disposition": "intentionallyOmitted",
              "reason": "Audience filtering belongs to builds_list, not exact build-number lookup.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[expired]",
              "disposition": "intentionallyOmitted",
              "reason": "Expiration filtering belongs to builds_list, not exact build-number lookup.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[id]",
              "disposition": "intentionallyOmitted",
              "reason": "A caller with a build ID should use builds_get; this finder is keyed by app and build number.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[processingState]",
              "disposition": "intentionallyOmitted",
              "reason": "Processing-state filtering belongs to builds_list, not exact build-number lookup.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "filter[usesNonExemptEncryption]",
              "disposition": "intentionallyOmitted",
              "reason": "Encryption-value filtering belongs to builds_list, not exact build-number lookup.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[betaBuildLocalizations]",
              "disposition": "intentionallyOmitted",
              "reason": "Beta build localizations are not included by the finder.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[betaGroups]",
              "disposition": "intentionallyOmitted",
              "reason": "Beta groups are not included by the finder.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[buildBundles]",
              "disposition": "intentionallyOmitted",
              "reason": "Build bundles are not included by the finder.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[icons]",
              "disposition": "intentionallyOmitted",
              "reason": "Build icons are not included by the finder.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[individualTesters]",
              "disposition": "intentionallyOmitted",
              "reason": "Individual testers are not included by the finder.",
              "reviewAtSpec": "4.4.1"
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "app_id",
          "sourceKind": "parameter",
          "operationId": "builds_getCollection",
          "location": "query",
          "appleName": "filter[app]"
        },
        {
          "toolField": "build_number",
          "sourceKind": "parameter",
          "operationId": "builds_getCollection",
          "location": "query",
          "appleName": "filter[version]"
        },
        {
          "toolField": "pre_release_platforms",
          "sourceKind": "parameter",
          "operationId": "builds_getCollection",
          "location": "query",
          "appleName": "filter[preReleaseVersion.platform]"
        },
        {
          "toolField": "pre_release_versions",
          "sourceKind": "parameter",
          "operationId": "builds_getCollection",
          "location": "query",
          "appleName": "filter[preReleaseVersion.version]"
        },
        {
          "toolField": "pre_release_version_ids",
          "sourceKind": "parameter",
          "operationId": "builds_getCollection",
          "location": "query",
          "appleName": "filter[preReleaseVersion]"
        },
        {
          "toolField": "sort",
          "sourceKind": "parameter",
          "operationId": "builds_getCollection",
          "location": "query",
          "appleName": "sort"
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          {
            "operationId": "builds_getCollection",
            "statusCode": "200",
            "mediaType": "application/json"
          }
        ],
        "fields": [
          {
            "outputField": "build",
            "operationId": "builds_getCollection",
            "jsonPointer": "/data/*",
            "localRole": "firstMatchingBuildProjection"
          },
          {
            "outputField": "success",
            "localRole": "True when a matching build exists; false is a local empty-result projection."
          }
        ]
      },
      "note": "Exact filter workflow with pre-release platform/version disambiguation and deterministic sorting; include and limit remain fixed for the singular projection."
    },
    {
