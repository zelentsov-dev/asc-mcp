              "reviewAtSpec": "4.4.1"
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "path",
          "appleName": "id"
        },
        {
          "toolField": "include_beta_detail",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "query",
          "appleName": "include"
        },
        {
          "toolField": "include_app",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "query",
          "appleName": "include"
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          {
            "operationId": "builds_getInstance",
            "statusCode": "200",
            "mediaType": "application/json"
          }
        ],
        "fields": [
          {
            "outputField": "build",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data"
          },
          {
            "outputField": "included",
            "operationId": "builds_getInstance",
            "jsonPointer": "/included"
          }
        ]
      },
      "note": "The two booleans derive the comma-separated include parameter; preReleaseVersion and buildBundles are always added. Output is a reduced projection and has no MCP output schema."
    },
