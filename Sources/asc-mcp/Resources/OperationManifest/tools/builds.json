{
  "workerKey": "builds",
  "tools": [
    {
      "tool": "builds_find_by_number",
      "kind": "direct",
      "status": "partial",
      "effect": "read",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "builds_getCollection",
          "method": "get",
          "path": "/v1/builds",
          "role": "primary"
        }
      ],
      "fields": [
        {
          "toolField": "app_id",
          "sourceKind": "parameter",
          "operationId": "builds_getCollection",
          "location": "query",
          "appleName": "filter[app]"
        },
        {
          "toolField": "build_number",
          "sourceKind": "parameter",
          "operationId": "builds_getCollection",
          "location": "query",
          "appleName": "filter[version]"
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          {
            "operationId": "builds_getCollection",
            "statusCode": "200",
            "mediaType": "application/json"
          }
        ],
        "fields": [
          {
            "outputField": "build",
            "operationId": "builds_getCollection",
            "jsonPointer": "/data/*",
            "localRole": "firstMatchingBuildProjection"
          },
          {
            "outputField": "success",
            "localRole": "True when a matching build exists; false is a local empty-result projection."
          }
        ]
      },
      "note": "Exact filter workflow; the handler fixes include and limit values locally and projects only the first matching build."
    },
    {
      "tool": "builds_get",
      "kind": "direct",
      "status": "partial",
      "effect": "read",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "builds_getInstance",
          "method": "get",
          "path": "/v1/builds/{id}",
          "role": "primary"
        }
      ],
      "fields": [
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "path",
          "appleName": "id"
        },
        {
          "toolField": "include_beta_detail",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "query",
          "appleName": "include"
        },
        {
          "toolField": "include_app",
          "sourceKind": "parameter",
          "operationId": "builds_getInstance",
          "location": "query",
          "appleName": "include"
        }
      ],
      "response": {
        "mode": "projection",
        "sources": [
          {
            "operationId": "builds_getInstance",
            "statusCode": "200",
            "mediaType": "application/json"
          }
        ],
        "fields": [
          {
            "outputField": "build",
            "operationId": "builds_getInstance",
            "jsonPointer": "/data"
          },
          {
            "outputField": "included",
            "operationId": "builds_getInstance",
            "jsonPointer": "/included"
          }
        ]
      },
      "note": "The two booleans derive the comma-separated include parameter; preReleaseVersion and buildBundles are always added. Output is a reduced projection and has no MCP output schema."
    },
