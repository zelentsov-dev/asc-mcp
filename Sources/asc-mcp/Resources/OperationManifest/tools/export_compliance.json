{
  "workerKey": "export_compliance",
  "tools": [
    {
      "tool": "export_compliance_attach_build_declaration",
      "kind": "compound",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "appEncryptionDeclarations_getInstance",
          "method": "get",
          "path": "/v1/appEncryptionDeclarations/{id}",
          "role": "supporting",
          "condition": "Preflight the declaration state before any build mutation.",
          "optionalParameterClassifications": [
            {
              "location": "query",
              "appleName": "include",
              "disposition": "intentionallyOmitted",
              "reason": "Attachment preflight only needs declaration approval metadata.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "query",
              "appleName": "limit[builds]",
              "disposition": "intentionallyOmitted",
              "reason": "Attachment preflight does not expand the deprecated builds relationship.",
              "reviewAtSpec": "4.4.1"
            }
          ],
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appEncryptionDeclarations]",
              "fixedValue": [
                "appDescription",
                "createdDate",
                "exempt",
                "containsProprietaryCryptography",
                "containsThirdPartyCryptography",
                "availableOnFrenchStore",
                "appEncryptionDeclarationState",
                "codeValue",
                "appEncryptionDeclarationDocument"
              ]
            }
          ]
        },
        {
          "operationId": "appEncryptionDeclarations_appEncryptionDeclarationDocument_getToOneRelated",
          "method": "get",
          "path": "/v1/appEncryptionDeclarations/{id}/appEncryptionDeclarationDocument",
          "role": "supporting",
          "condition": "Require a COMPLETE document before mutating the build.",
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appEncryptionDeclarationDocuments]",
              "fixedValue": [
                "fileSize",
                "fileName",
                "downloadUrl",
                "sourceFileChecksum",
                "assetDeliveryState"
              ]
            }
          ]
        },
        {
          "operationId": "builds_updateInstance",
          "method": "patch",
          "path": "/v1/builds/{id}",
          "role": "primary",
          "condition": "After all preflight checks pass, use Apple's supported Build update replacement to set the declaration relationship.",
          "optionalParameterClassifications": [
            {
              "location": "body",
              "appleName": "/data/attributes/expired",
              "disposition": "intentionallyOmitted",
              "reason": "Attachment does not mutate build expiration state.",
              "reviewAtSpec": "4.4.1"
            },
            {
              "location": "body",
              "appleName": "/data/attributes/usesNonExemptEncryption",
              "disposition": "intentionallyOmitted",
              "reason": "Attachment does not change the build encryption answer; builds_update_encryption owns that mutation.",
              "reviewAtSpec": "4.4.1"
            }
          ],
          "inputs": [
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/type",
              "fixedValue": "builds"
            },
            {
              "sourceKind": "fixed",
              "jsonPointer": "/data/relationships/appEncryptionDeclaration/data/type",
              "fixedValue": "appEncryptionDeclarations"
            }
          ]
        },
        {
          "operationId": "builds_appEncryptionDeclaration_getToOneRelated",
          "method": "get",
          "path": "/v1/builds/{id}/appEncryptionDeclaration",
          "role": "supporting",
          "condition": "Post-verify that the build resolves to the intended declaration ID.",
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appEncryptionDeclarations]",
              "fixedValue": [
                "appDescription",
                "createdDate",
                "exempt",
                "containsProprietaryCryptography",
                "containsThirdPartyCryptography",
                "availableOnFrenchStore",
                "appEncryptionDeclarationState",
                "codeValue",
                "appEncryptionDeclarationDocument"
              ]
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "builds_updateInstance",
          "location": "path",
          "appleName": "id"
        },
        {
          "toolField": "build_id",
          "sourceKind": "requestBody",
          "operationId": "builds_updateInstance",
          "jsonPointer": "/data/id"
        },
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "builds_appEncryptionDeclaration_getToOneRelated",
          "location": "path",
          "appleName": "id"
        },
        {
          "toolField": "declaration_id",
          "sourceKind": "parameter",
          "operationId": "appEncryptionDeclarations_getInstance",
          "location": "path",
          "appleName": "id"
        },
        {
          "toolField": "declaration_id",
          "sourceKind": "parameter",
          "operationId": "appEncryptionDeclarations_appEncryptionDeclarationDocument_getToOneRelated",
          "location": "path",
          "appleName": "id"
        },
        {
          "toolField": "declaration_id",
          "sourceKind": "requestBody",
          "operationId": "builds_updateInstance",
          "jsonPointer": "/data/relationships/appEncryptionDeclaration/data/id"
        }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "appEncryptionDeclarations_getInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "appEncryptionDeclarations_appEncryptionDeclarationDocument_getToOneRelated", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "builds_updateInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "builds_appEncryptionDeclaration_getToOneRelated", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": [
          {
            "outputField": "attachmentVerified",
            "localRole": "True only after post-verification resolves the intended declaration ID."
          },
          {
            "outputField": "declaration",
            "operationId": "builds_appEncryptionDeclaration_getToOneRelated",
            "jsonPointer": "/data"
          }
        ]
      },
      "note": "Uses builds_updateInstance as the replacement documented by Apple at https://developer.apple.com/documentation/appstoreconnectapi/patch-v1-builds-_id_ and accepts only that operation's exact HTTP 200 response. Pinned OpenAPI 4.4.1 omits a deprecated flag for the direct relationship PATCH, while current Apple DocC marks it deprecated at https://developer.apple.com/documentation/appstoreconnectapi/patch-v1-builds-_id_-relationships-appencryptiondeclaration and directs clients to Modify a build; its HTTP 204 contract is not used here. The pinned-spec-deprecated declaration-to-build POST also remains deferred. Any ambiguous update or failed post-verification is an unverified mutation with retrySafe=false."
    },
    {
      "tool": "export_compliance_check_release_readiness",
      "kind": "compound",
      "status": "partial",
      "effect": "read",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "builds_getInstance",
          "method": "get",
          "path": "/v1/builds/{id}",
          "role": "primary",
          "optionalParameterClassifications": [
            { "location": "query", "appleName": "include", "disposition": "intentionallyOmitted", "reason": "The export gate reads only Build attributes and the app relationship identifier.", "reviewAtSpec": "4.4.1" },
            { "location": "query", "appleName": "limit[betaBuildLocalizations]", "disposition": "intentionallyOmitted", "reason": "Beta localizations are outside export compliance.", "reviewAtSpec": "4.4.1" },
            { "location": "query", "appleName": "limit[betaGroups]", "disposition": "intentionallyOmitted", "reason": "Beta groups are outside export compliance.", "reviewAtSpec": "4.4.1" },
            { "location": "query", "appleName": "limit[buildBundles]", "disposition": "intentionallyOmitted", "reason": "Build bundles are outside this gate.", "reviewAtSpec": "4.4.1" },
            { "location": "query", "appleName": "limit[icons]", "disposition": "intentionallyOmitted", "reason": "Build icons are outside this gate.", "reviewAtSpec": "4.4.1" },
            { "location": "query", "appleName": "limit[individualTesters]", "disposition": "intentionallyOmitted", "reason": "Individual testers are outside export compliance.", "reviewAtSpec": "4.4.1" }
          ],
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[builds]",
              "fixedValue": ["version", "processingState", "expired", "usesNonExemptEncryption", "app"]
            }
          ]
        },
        {
          "operationId": "builds_appEncryptionDeclaration_getToOneRelated",
          "method": "get",
          "path": "/v1/builds/{id}/appEncryptionDeclaration",
          "role": "conditional",
          "condition": "Only when usesNonExemptEncryption is true; 404 means no declaration is attached.",
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appEncryptionDeclarations]",
              "fixedValue": [
                "appDescription",
                "createdDate",
                "exempt",
                "containsProprietaryCryptography",
                "containsThirdPartyCryptography",
                "availableOnFrenchStore",
                "appEncryptionDeclarationState",
                "codeValue",
                "appEncryptionDeclarationDocument"
              ]
            }
          ]
        },
        {
          "operationId": "appEncryptionDeclarations_appEncryptionDeclarationDocument_getToOneRelated",
          "method": "get",
          "path": "/v1/appEncryptionDeclarations/{id}/appEncryptionDeclarationDocument",
          "role": "conditional",
          "condition": "Only for an attached non-exempt declaration; 404 means no document exists.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": ["builds_appEncryptionDeclaration_getToOneRelated:/data/id"],
              "localRole": "Use the declaration ID returned by the build relationship lookup."
            },
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appEncryptionDeclarationDocuments]",
              "fixedValue": ["fileSize", "fileName", "downloadUrl", "sourceFileChecksum", "assetDeliveryState"]
            }
          ]
        }
      ],
      "fields": [
        { "toolField": "build_id", "sourceKind": "parameter", "operationId": "builds_getInstance", "location": "path", "appleName": "id" },
        { "toolField": "build_id", "sourceKind": "parameter", "operationId": "builds_appEncryptionDeclaration_getToOneRelated", "location": "path", "appleName": "id" }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "builds_getInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "builds_appEncryptionDeclaration_getToOneRelated", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "appEncryptionDeclarations_appEncryptionDeclarationDocument_getToOneRelated", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": [
          { "outputField": "status", "localRole": "Derive READY, PENDING, or BLOCKED without treating unknown nullable state as success." },
          { "outputField": "exportComplianceReady", "localRole": "True only when the EXPORT_COMPLIANCE_ONLY gate passes; this is not a global release-ready claim." },
          { "outputField": "checks", "localRole": "Actionable build, declaration, and document gate checks." },
          { "outputField": "actions", "localRole": "State-specific next steps; unknown build encryption includes the required true-or-false selection placeholder, retained uploads include path and checksum-receipt placeholders, and unsupported declaration states route to App Store Connect or Apple Support." },
          { "outputField": "appStoreSubmissionStatus", "localRole": "Always NOT_DETERMINED because non-export release requirements are outside this tool." }
        ]
      },
      "note": "A false encryption answer needs no declaration. A true answer requires an attached APPROVED non-exempt declaration and COMPLETE document. Build processingState and expired are informational because this tool is scoped only to export compliance. AWAITING_UPLOAD points to checksum-bound resume, UPLOAD_COMPLETE points to inspection, document creation is suggested only for CREATED or REJECTED declarations, and missing, nullable, future, failed, or inconsistent states fail closed."
    },
    {
      "tool": "export_compliance_create_declaration",
      "kind": "direct",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "appEncryptionDeclarations_createInstance",
          "method": "post",
          "path": "/v1/appEncryptionDeclarations",
          "role": "primary",
          "inputs": [
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "appEncryptionDeclarations" },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/app/data/type", "fixedValue": "apps" }
          ]
        }
      ],
      "fields": [
        { "toolField": "app_id", "sourceKind": "requestBody", "operationId": "appEncryptionDeclarations_createInstance", "jsonPointer": "/data/relationships/app/data/id" },
        { "toolField": "app_description", "sourceKind": "requestBody", "operationId": "appEncryptionDeclarations_createInstance", "jsonPointer": "/data/attributes/appDescription" },
        { "toolField": "contains_proprietary_cryptography", "sourceKind": "requestBody", "operationId": "appEncryptionDeclarations_createInstance", "jsonPointer": "/data/attributes/containsProprietaryCryptography" },
        { "toolField": "contains_third_party_cryptography", "sourceKind": "requestBody", "operationId": "appEncryptionDeclarations_createInstance", "jsonPointer": "/data/attributes/containsThirdPartyCryptography" },
        { "toolField": "available_on_french_store", "sourceKind": "requestBody", "operationId": "appEncryptionDeclarations_createInstance", "jsonPointer": "/data/attributes/availableOnFrenchStore" }
      ],
      "response": {
        "mode": "projection",
        "sources": [{ "operationId": "appEncryptionDeclarations_createInstance", "statusCode": "201", "mediaType": "application/json" }],
        "fields": [
          { "outputField": "declaration", "operationId": "appEncryptionDeclarations_createInstance", "jsonPointer": "/data" },
          { "outputField": "creationState", "localRole": "confirmed for a validated 201 resource, committed_unverified for a malformed or identity-invalid successful response, commit_unknown for network, 408, or 5xx uncertainty, and rejected for a deterministic rejection." },
          { "outputField": "commitConfirmed", "localRole": "True for a validated resource or a successful response whose resource could not be verified; false when transport or status does not prove acceptance." },
          { "outputField": "retrySafe", "localRole": "False after confirmed, committed-unverified, or commit-unknown outcomes; true only after a deterministic rejection." },
          { "outputField": "inspection", "localRole": "For committed-unverified or commit-unknown outcomes, call export_compliance_list_declarations with the original app_id before any retry." }
        ]
      },
      "note": "Sends exactly the four required questionnaire attributes and required app linkage from OpenAPI 4.4.1; obsolete platform, usesEncryption, and compliance-code inputs are not exposed. A confirmed response requires the mandatory configured-origin canonical resource self-link. The non-idempotent POST distinguishes committed-but-unverified success, unknown commit state, and deterministic rejection so an ambiguous response never invites a blind duplicate create."
    },
    {
      "tool": "export_compliance_create_document",
      "kind": "compound",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "appEncryptionDeclarations_getInstance",
          "method": "get",
          "path": "/v1/appEncryptionDeclarations/{id}",
          "role": "supporting",
          "condition": "Preflight a mutable declaration state before creating a reservation.",
          "optionalParameterClassifications": [
            { "location": "query", "appleName": "include", "disposition": "intentionallyOmitted", "reason": "Reservation preflight only needs declaration state.", "reviewAtSpec": "4.4.1" },
            { "location": "query", "appleName": "limit[builds]", "disposition": "intentionallyOmitted", "reason": "Reservation preflight does not expand deprecated builds.", "reviewAtSpec": "4.4.1" }
          ],
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appEncryptionDeclarations]",
              "fixedValue": [
                "appDescription",
                "createdDate",
                "exempt",
                "containsProprietaryCryptography",
                "containsThirdPartyCryptography",
                "availableOnFrenchStore",
                "appEncryptionDeclarationState",
                "codeValue",
                "appEncryptionDeclarationDocument"
              ]
            }
          ]
        },
        {
          "operationId": "appEncryptionDeclarations_appEncryptionDeclarationDocument_getToOneRelated",
          "method": "get",
          "path": "/v1/appEncryptionDeclarations/{id}/appEncryptionDeclarationDocument",
          "role": "supporting",
          "condition": "Reject duplicate reservation creation when the declaration already has a document.",
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appEncryptionDeclarationDocuments]",
              "fixedValue": ["fileSize", "fileName", "downloadUrl", "sourceFileChecksum", "assetDeliveryState"]
            }
          ]
        },
        {
          "operationId": "appEncryptionDeclarationDocuments_createInstance",
          "method": "post",
          "path": "/v1/appEncryptionDeclarationDocuments",
          "role": "primary",
          "condition": "After preflight and immutable snapshot creation, reserve one document upload.",
          "inputs": [
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "appEncryptionDeclarationDocuments" },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/appEncryptionDeclaration/data/type", "fixedValue": "appEncryptionDeclarations" }
          ]
        },
        {
          "operationId": "appEncryptionDeclarationDocuments_updateInstance",
          "method": "patch",
          "path": "/v1/appEncryptionDeclarationDocuments/{id}",
          "role": "supporting",
          "condition": "Only after the reservation returns exact AWAITING_UPLOAD and every signed transfer of the same immutable snapshot succeeds, commit its checksum with uploaded=true.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": ["appEncryptionDeclarationDocuments_createInstance:/data/id"],
              "localRole": "Commit only the exact document returned by this reservation operation."
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/id",
              "derivedFrom": ["appEncryptionDeclarationDocuments_createInstance:/data/id"],
              "localRole": "Copy the reservation response ID into the commit resource identifier."
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "appEncryptionDeclarationDocuments" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/attributes/sourceFileChecksum",
              "derivedFrom": ["file_path", "appEncryptionDeclarationDocuments_createInstance:/data/attributes/uploadOperations"],
              "localRole": "Commit the lowercase MD5 returned after transferring the immutable snapshot through this reservation's signed upload operations."
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/attributes/uploaded", "fixedValue": true }
          ]
        },
        {
          "operationId": "appEncryptionDeclarationDocuments_getInstance",
          "method": "get",
          "path": "/v1/appEncryptionDeclarationDocuments/{id}",
          "role": "supporting",
          "condition": "Reconcile an ambiguous commit and poll the committed resource until COMPLETE, FAILED, or the bounded poll budget is exhausted.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": ["appEncryptionDeclarationDocuments_createInstance:/data/id"],
              "localRole": "Inspect only the exact document returned by this reservation operation."
            }
          ]
        }
      ],
      "fields": [
        { "toolField": "declaration_id", "sourceKind": "parameter", "operationId": "appEncryptionDeclarations_getInstance", "location": "path", "appleName": "id" },
        { "toolField": "declaration_id", "sourceKind": "parameter", "operationId": "appEncryptionDeclarations_appEncryptionDeclarationDocument_getToOneRelated", "location": "path", "appleName": "id" },
        { "toolField": "declaration_id", "sourceKind": "requestBody", "operationId": "appEncryptionDeclarationDocuments_createInstance", "jsonPointer": "/data/relationships/appEncryptionDeclaration/data/id" },
        { "toolField": "file_path", "sourceKind": "local", "localRole": "Create an immutable local snapshot; never return signed upload URLs or headers." },
        { "toolField": "file_path", "sourceKind": "derived", "operationId": "appEncryptionDeclarationDocuments_createInstance", "jsonPointer": "/data/attributes/fileSize", "derivedFrom": ["file_path"], "localRole": "Derive byte size from the snapshot." },
        { "toolField": "file_path", "sourceKind": "derived", "operationId": "appEncryptionDeclarationDocuments_createInstance", "jsonPointer": "/data/attributes/fileName", "derivedFrom": ["file_path"], "localRole": "Derive file name from the snapshot." }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "appEncryptionDeclarations_getInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "appEncryptionDeclarations_appEncryptionDeclarationDocument_getToOneRelated", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "appEncryptionDeclarationDocuments_createInstance", "statusCode": "201", "mediaType": "application/json" },
          { "operationId": "appEncryptionDeclarationDocuments_updateInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "appEncryptionDeclarationDocuments_getInstance", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": [
          { "outputField": "document", "localRole": "Latest safe resource projection after commit, reconciliation, or bounded delivery polling." },
          { "outputField": "sourceFileChecksumReceipt", "localRole": "When reservation creation is ambiguous, or a known precommit reservation has no conflicting Apple checksum binding, return the lowercase MD5 of the immutable snapshot so later inspection and resume can require the exact same bytes." },
          { "outputField": "checksumBindingConflict", "localRole": "True when checksum evidence cannot be reconciled safely: without an Apple binding the caller receipt and snapshot must agree, while with a binding Apple and the snapshot must agree. Omit the resume receipt and require inspection instead of suggesting another transfer." },
          { "outputField": "retrySafe", "localRole": "True only before reservation or after a deterministic reservation rejection; false for retained, ambiguous, committed, pending, or failed outcomes." },
          { "outputField": "inspection", "localRole": "When reservation identity or commit state is unresolved, inspect the declaration or retained document before any retry." }
        ]
      },
      "note": "Preflights declaration state and confirmed absence, then reserves, transfers, commits, and polls using one immutable snapshot. Transfer is allowed only from exact AWAITING_UPLOAD. Deterministic reservation rejection is retryable after input correction; transport, 408, 5xx, malformed-success, invalid-identity, retained precommit, and ambiguous commit outcomes remain unsafe until inspection. Every post-snapshot unresolved reservation returns the immutable snapshot checksum receipt so a document later found by inspection can be resumed only with the original bytes. The tool never exposes assetToken, downloadUrl, upload URL, or request headers."
    },
    {
