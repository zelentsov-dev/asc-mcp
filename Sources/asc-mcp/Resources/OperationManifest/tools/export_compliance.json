          "method": "get",
          "path": "/v1/builds/{id}/appEncryptionDeclaration",
          "role": "primary",
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "fields[appEncryptionDeclarations]",
