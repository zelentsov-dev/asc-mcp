    {
      "tool": "screenshots_upload",
      "kind": "compound",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "appScreenshots_createInstance",
          "method": "post",
          "path": "/v1/appScreenshots",
          "role": "supporting",
          "condition": "Reserves the asset and returns signed upload operations.",
          "inputs": [
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "appScreenshots" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/attributes/fileName",
              "derivedFrom": ["file_path"],
              "localRole": "Derive the reservation file name from the local file path."
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/attributes/fileSize",
              "derivedFrom": ["file_path"],
              "localRole": "Read the local file size before reserving the asset."
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/appScreenshotSet/data/type", "fixedValue": "appScreenshotSets" }
          ]
        },
        {
          "operationId": "appScreenshots_updateInstance",
          "method": "patch",
          "path": "/v1/appScreenshots/{id}",
          "role": "primary",
          "condition": "Commits the uploaded asset with sourceFileChecksum and uploaded=true.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": ["appScreenshots_createInstance:/data/id"],
              "localRole": "Use the screenshot ID returned by the reservation response."
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/id",
              "derivedFrom": ["appScreenshots_createInstance:/data/id"],
              "localRole": "Copy the reservation response ID into the commit resource identifier."
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "appScreenshots" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/attributes/sourceFileChecksum",
              "derivedFrom": ["file_path", "appScreenshots_createInstance:/data/attributes/uploadOperations"],
              "localRole": "Use the checksum returned after uploading the local file through Apple's signed upload operations."
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/attributes/uploaded", "fixedValue": true }
          ]
        }
      ],
      "fields": [
        { "toolField": "set_id", "sourceKind": "requestBody", "operationId": "appScreenshots_createInstance", "jsonPointer": "/data/relationships/appScreenshotSet/data/id" },
        { "toolField": "file_path", "sourceKind": "local", "localRole": "assetFileSource", "derivedFrom": ["fileName", "fileSize", "sourceFileChecksum"] }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "appScreenshots_createInstance", "statusCode": "201", "mediaType": "application/json" },
          { "operationId": "appScreenshots_updateInstance", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": []
      },
      "note": "The bytes are uploaded between reserve and commit to Apple-provided signed URLs; those external upload operations are runtime response data, not OpenAPI operations."
    },
    {
      "tool": "screenshots_upload_batch",
      "kind": "compound",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "appScreenshots_createInstance",
          "method": "post",
          "path": "/v1/appScreenshots",
          "role": "supporting",
          "condition": "Repeated once per local file to reserve each asset.",
          "inputs": [
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "appScreenshots" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/attributes/fileName",
              "derivedFrom": ["file_paths"],
              "localRole": "Derive each reservation file name from the current local path in the batch."
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/attributes/fileSize",
              "derivedFrom": ["file_paths"],
              "localRole": "Read each current local file size before reserving its asset."
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/appScreenshotSet/data/type", "fixedValue": "appScreenshotSets" }
          ]
        },
        {
          "operationId": "appScreenshots_updateInstance",
          "method": "patch",
          "path": "/v1/appScreenshots/{id}",
          "role": "primary",
          "condition": "Repeated once per successfully uploaded local file to commit each asset.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": ["appScreenshots_createInstance:/data/id"],
              "localRole": "Use the current screenshot reservation ID for the matching batch item."
            },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/id",
              "derivedFrom": ["appScreenshots_createInstance:/data/id"],
              "localRole": "Copy the current reservation ID into the matching commit resource identifier."
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "appScreenshots" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/attributes/sourceFileChecksum",
              "derivedFrom": ["file_paths", "appScreenshots_createInstance:/data/attributes/uploadOperations"],
              "localRole": "Use the checksum returned after uploading the current batch file through Apple's signed upload operations."
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/attributes/uploaded", "fixedValue": true }
          ]
        }
      ],
      "fields": [
        { "toolField": "set_id", "sourceKind": "requestBody", "operationId": "appScreenshots_createInstance", "jsonPointer": "/data/relationships/appScreenshotSet/data/id" },
        { "toolField": "file_paths", "sourceKind": "local", "localRole": "batchAssetFileSources", "derivedFrom": ["per-file fileName", "per-file fileSize", "per-file sourceFileChecksum"] }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "appScreenshots_createInstance", "statusCode": "201", "mediaType": "application/json" },
          { "operationId": "appScreenshots_updateInstance", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": []
      },
      "note": "The two Apple operations and signed-URL byte upload are repeated per file; the MCP aggregates per-file success and failure results."
    },
