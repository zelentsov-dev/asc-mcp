    {
      "tool": "builds_set_beta_localization",
      "kind": "compound",
      "status": "partial",
      "effect": "write",
      "implementationState": "asBuilt",
      "operations": [
        {
          "operationId": "betaBuildLocalizations_getCollection",
          "method": "get",
          "path": "/v1/betaBuildLocalizations",
          "role": "supporting",
          "inputs": [
            {
              "sourceKind": "fixed",
              "location": "query",
              "appleName": "limit",
              "fixedValue": 1
            }
          ]
        },
        {
          "operationId": "betaBuildLocalizations_createInstance",
          "method": "post",
          "path": "/v1/betaBuildLocalizations",
          "role": "primary",
          "condition": "No existing localization has the requested locale.",
          "inputs": [
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "betaBuildLocalizations" },
            { "sourceKind": "fixed", "jsonPointer": "/data/relationships/build/data/type", "fixedValue": "builds" }
          ]
        },
        {
          "operationId": "betaBuildLocalizations_updateInstance",
          "method": "patch",
          "path": "/v1/betaBuildLocalizations/{id}",
          "role": "conditional",
          "condition": "An existing localization has the requested locale.",
          "inputs": [
            {
              "sourceKind": "derived",
              "location": "path",
              "appleName": "id",
              "derivedFrom": ["betaBuildLocalizations_getCollection:/data/*/id"],
              "localRole": "useFirstLocaleMatchedLocalizationIdentifierForPath"
            },
            { "sourceKind": "fixed", "jsonPointer": "/data/type", "fixedValue": "betaBuildLocalizations" },
            {
              "sourceKind": "derived",
              "jsonPointer": "/data/id",
              "derivedFrom": ["betaBuildLocalizations_getCollection:/data/*/id"],
              "localRole": "copyLocaleMatchedLocalizationIdentifierToRequestBody"
            }
          ]
        }
      ],
      "fields": [
        {
          "toolField": "build_id",
          "sourceKind": "parameter",
          "operationId": "betaBuildLocalizations_getCollection",
          "location": "query",
          "appleName": "filter[build]"
        },
        {
          "toolField": "locale",
          "sourceKind": "parameter",
          "operationId": "betaBuildLocalizations_getCollection",
          "location": "query",
          "appleName": "filter[locale]"
        },
        {
          "toolField": "build_id",
          "sourceKind": "requestBody",
          "operationId": "betaBuildLocalizations_createInstance",
          "jsonPointer": "/data/relationships/build/data/id"
        },
        {
          "toolField": "locale",
          "sourceKind": "requestBody",
          "operationId": "betaBuildLocalizations_createInstance",
          "jsonPointer": "/data/attributes/locale"
        },
        {
          "toolField": "whats_new",
          "sourceKind": "requestBody",
          "operationId": "betaBuildLocalizations_createInstance",
          "jsonPointer": "/data/attributes/whatsNew"
        },
        {
          "toolField": "whats_new",
          "sourceKind": "requestBody",
          "operationId": "betaBuildLocalizations_updateInstance",
          "jsonPointer": "/data/attributes/whatsNew"
        },
        {
          "toolField": "feedback_email",
          "sourceKind": "local",
          "localRole": "Deprecated input rejected before network access.",
          "omissionReason": "Apple 4.4.1 places feedbackEmail on BetaAppLocalization, not BetaBuildLocalization."
        },
        {
          "toolField": "marketing_url",
          "sourceKind": "local",
          "localRole": "Deprecated input rejected before network access.",
          "omissionReason": "Apple 4.4.1 places marketingUrl on BetaAppLocalization, not BetaBuildLocalization."
        },
        {
          "toolField": "privacy_policy_url",
          "sourceKind": "local",
          "localRole": "Deprecated input rejected before network access.",
          "omissionReason": "Apple 4.4.1 places privacyPolicyUrl on BetaAppLocalization, not BetaBuildLocalization."
        },
        {
          "toolField": "tv_os_privacy_policy",
          "sourceKind": "local",
          "localRole": "Deprecated input rejected before network access.",
          "omissionReason": "Apple 4.4.1 places tvOsPrivacyPolicy on BetaAppLocalization, not BetaBuildLocalization."
        }
      ],
      "response": {
        "mode": "aggregate",
        "sources": [
          { "operationId": "betaBuildLocalizations_createInstance", "statusCode": "201", "mediaType": "application/json" },
          { "operationId": "betaBuildLocalizations_updateInstance", "statusCode": "200", "mediaType": "application/json" },
          { "operationId": "betaBuildLocalizations_getCollection", "statusCode": "200", "mediaType": "application/json" }
        ],
        "fields": [
          {
            "outputField": "localization",
            "operationId": "betaBuildLocalizations_createInstance",
            "jsonPointer": "/data"
          },
          {
            "outputField": "localization",
            "operationId": "betaBuildLocalizations_updateInstance",
            "jsonPointer": "/data"
          },
          {
            "outputField": "action",
            "localRole": "Created or updated branch selected from the build-and-locale-filtered collection result."
          },
          {
            "outputField": "success",
            "localRole": "True after Apple creates or updates the localization."
          }
        ]
      },
      "note": "Create-or-update workflow uses Apple-side build and locale filters to find an existing resource across the full collection, then serializes only locale and whatsNew. Deprecated BetaAppLocalization-only inputs remain discoverable and are rejected before network access with replacement tool guidance."
    },
